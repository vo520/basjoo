# Example environment configuration for the Basjoo agent platform
# Copy this file to .env and update the values as needed

# ========== Database ==========
# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# SQLite (optional for development)
# DATABASE_URL=sqlite:////app/data/basjoo.db

# ========== Redis ==========
# REDIS_URL=redis://host:6379/0
REDIS_URL=
REDIS_CACHE_TTL=3600
REDIS_RATE_LIMIT_TTL=60

# ========== Qdrant vector database ==========
# Qdrant stores per-KB vector collections for multi-tenant knowledge isolation.
# Default: http://localhost:6333 (Docker: http://qdrant:6333)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_TIMEOUT=30.0

# ========== JWT authentication ==========
# You can leave this empty for zero-config deployments:
# the app will generate and persist a key to SECRET_KEY_FILE on startup.
# If you want to set your own, use a strong random value.
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== Default widget agent identity ==========
# Leave empty for zero-config deployments: the app will generate and persist
# a default widget agent ID to /app/data/.agent_id on first startup.
# Set this only if you need to preserve or restore a known widget agent ID,
# for example when migrating servers and keeping old embed codes working.
DEFAULT_AGENT_ID=

# ========== CORS ==========
# Zero-config deployments default to permissive settings so the widget
# and admin dashboard work out of the box.
# For production, tighten this to your real domain allowlist.
ALLOWED_ORIGINS=*
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,Accept

# ========== LLM API settings ==========
# Configure the API key for the AI provider you want to use

# DeepSeek (default)
DEEPSEEK_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# Anthropic Claude
# ANTHROPIC_API_KEY=

# Google Gemini
# GOOGLE_API_KEY=

# Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=

# ========== URL fetching & embeddings ==========
# Scrapling microservice handles all URL fetching automatically.
# JINA_API_KEY is used by the KB system for embeddings (vector generation for RAG).
# JINA_API_KEY=

# ========== Application ==========
APP_NAME=Basjoo
APP_PORT=8000

# ========== HTTPS (optional) ==========
# Put certificate files under ./ssl/ at the project root to enable HTTPS automatically (port 443)
# cert.pem or fullchain.pem - SSL certificate file
# key.pem                   - SSL private key file
#
# Without certificates, only HTTP (port 80) will be enabled
#
# Optional canonical domain for nginx host matching
# When set, nginx only serves this domain and rejects direct IP or other Host access.
# With certificates present, HTTP requests redirect to HTTPS for this domain.
# SERVER_DOMAIN=example.com

# Rate limiting
DEFAULT_RATE_LIMIT=100
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_BURST_SIZE=200

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ========== API key encryption (optional) ==========
# You can leave this empty for zero-config deployments:
# bootstrap-env.sh can generate ENCRYPTION_KEY automatically.
# On first startup, the system can also generate and save a key to /app/data/.encryption_key
ENCRYPTION_KEY=
# To override the default key file paths:
SECRET_KEY_FILE=/app/data/.secret_key
ENCRYPTION_KEY_FILE=/app/data/.encryption_key

# ========== E2E Testing Configuration ==========
# For widget cross-origin tests, add to /etc/hosts:
#   127.0.0.1 allowed.local
#   127.0.0.1 blocked.local
HOST_ALLOWED_URL=http://allowed.local:8080
HOST_BLOCKED_URL=http://blocked.local:8081
